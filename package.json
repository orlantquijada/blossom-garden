{
  "name": "blossom-garden",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @blossom-garden/web dev",
    "build": "pnpm -r build",
    "vercel-build": "NITRO_PRESET=vercel pnpm --filter @blossom-garden/web build",
    "check": "ultracite check",
